{
  "manifest_version": 3,
  "name": "柒幻 扬琴",
  "version": "1.5",
  "description": "数据填充工具",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "显示/隐藏侧边栏"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "vendor/onnxruntime-web/ort.min.js", "ai_autofill_content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "sidebar.html",
        "sidebar.js",
        "sidebar_ai_addon.js",
        "styles.css",
        "vendor/onnxruntime-web/ort.min.js",
        "vendor/onnxruntime-web/ort-wasm-simd-threaded.jsep.mjs",
        "vendor/onnxruntime-web/ort-wasm-simd.jsep.mjs",
        "vendor/onnxruntime-web/ort-wasm-simd-threaded.jsep.wasm",
        "vendor/onnxruntime-web/ort-wasm-simd.jsep.wasm",
        "vendor/onnxruntime-web/ort-wasm-simd-threaded.wasm",
        "vendor/onnxruntime-web/ort-wasm-simd.wasm",
        "vendor/onnxruntime-web/ort-wasm-threaded.wasm",
        "vendor/onnxruntime-web/ort-wasm.wasm"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
